body { 
    margin: 0;
    padding: 0;
    color: rgb(255,255,255);
    background-color: rgb(40,40,40);
    font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
    font-size: 12pt; 
}

a { 
    color: rgb(150,255,100);
    text-decoration: none; 
}

h1,h2,h3 { 
    color: rgb(255,255,255); 
}

p.justified { 
    text-align: justify; 
}

span.conf {
    font-style: italic;
}

a:hover { color: rgb(100,200,200); }

#div.header { 
#    height: 100px; 
#    background-color: rgb(80,80,80);
#    padding-top: 2%;
#}
div.footer { 
    background-color: #aa8; 
}

div.content { 
    margin-left: 7.5%; 
    margin-bottom: 2%; 
    margin-top: 2%;
    width: 80%; 
}

div.main { 
#    background-color: rgb(60,60,60);
    padding-left: 8%;
    padding-top: 2%;
    padding-bottom: 1%;
    text-align: justify; 
}

div.section h1 { 
    font-variant: small-caps; 
}
div.section { 
    width: 80%; 
}

div.abstract { 
    font-size: 10pt; 
    padding-left: 10px; 
    padding-top: 5px; 
    color: rgb(250,250,250); 
    width: 90%; 
    text-align: justify; 
    margin-bottom: 5px; 
    display: none;
}

span.abstract { 
    font-size: 10pt; 
    padding-left: 10px; 
    padding-top: 5px; 
    color: rgb(250,150,150); 
    width: 90%; 
    text-align: justify; 
    margin-bottom: 5px; 
    display: none;
}


h3.title {
    padding-top: 10px;
    border-top-style: solid;
    border-width: 1px;
    border-color: green;
}

h4.title {
    padding-top: 10px;
    border-top-style: solid;
    border-width: 1px;
    border-color: green;
}

span.title {
    font-size: 12pt;
    font-weight: bold;
    padding-top: 10px;
}

div.paper {
    width: 80%;
    font-size: 11pt;
    border-top-style: solid;
    border-width: 1px;
    border-color: green;
    padding-top: 10px;
    padding-bottom: 10px;
}

div.line {
    font-size: 11pt;
    text-align:justify;
    margin-right:150px;
    margin-left:15px;
    padding-top: 10px;
    padding-bottom: 10px;
}

div.hspace {
    padding-top: 10px;
    padding-bottom: 10px;
}

h3.category {
    padding-top: 20px;
    border-top-style: solid;
    border-width: 2px;
    border-color: white;
}
